{
  "name": "sediment",
  "version": "1.1.0",
  "description": "A local-first macOS app that collects everything you save during the day onto one canvas per day.",
  "main": "./out/main/index.mjs",
  "author": "Nishil Faldu",
  "license": "MIT",
  "homepage": "https://github.com/nishilfaldu/sediment",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "node node_modules/electron/install.js && electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/besley": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tanstack/react-query": "^5.100.14",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.3.0",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.11",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
